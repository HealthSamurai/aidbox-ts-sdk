{
	"name": "@health-samurai/aidbox-client",
	"version": "0.0.0-alpha.1",
	"description": "A client library for communicating with Aidbox",
	"author": "Health Samurai",
	"type": "module",
	"main": "./dist/src/index.js",
	"types": "./dist/src/index.types.d.ts",
	"files": [
		"dist"
	],
	"exports": {
		".": "./dist/src/index.js"
	},
	"scripts": {
		"build": "rm -rf dist && mkdir -p dist && swc src -d dist -D && pnpm exec tsc -b --force && echo success",
		"format": "pnpm exec biome format",
		"format:check": "pnpm exec biome format",
		"format:fix": "pnpm exec biome format --write",
		"lint": "pnpm exec biome check",
		"lint:check": "pnpm exec biome check",
		"lint:fix": "pnpm exec biome check --write",
		"typecheck": "pnpm exec tsc -b --noEmit",
		"generate-types": "pnpm exec tsx scripts/generate-types.ts"
	},
	"dependencies": {
		"@types/js-cookie": "^3.0.6",
		"js-cookie": "^3.0.5",
		"yaml": "^2.8.1"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/HealthSamurai/aidbox-ts-sdk"
	},
	"devDependencies": {
		"@atomic-ehr/codegen": "canary",
		"@types/node": "^24.2.0",
		"tsx": "^4.20.4",
		"typescript": "~5.8.3"
	}
}
